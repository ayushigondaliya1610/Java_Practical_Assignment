package ejb;

import jakarta.ejb.Stateful;
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.ResultSet;

/**
 *
 * @author tejan
 */
@Stateful
public class VisitBean implements VisitBeanLocal {
    private int visitCount = 0;

    private final String url = "jdbc:mysql://localhost:3306/totalvisitdb";
    private final String user = "root";
    private final String password = "root";
    
    @Override
    public int recordVisit(String ipAddress) {
     
        try{
             // Load MySQL Driver
            Class.forName("com.mysql.cj.jdbc.Driver");

            Connection con = DriverManager.getConnection(url, user, password);

            // Check if IP exists
            PreparedStatement ps = con.prepareStatement(
                "SELECT visit_count FROM page_visits WHERE ip_address=?"
            );
            ps.setString(1, ipAddress);
            ResultSet rs = ps.executeQuery();

            if (rs.next()) {
                visitCount = rs.getInt("visit_count") + 1;

                PreparedStatement update = con.prepareStatement(
                    "UPDATE page_visits SET visit_count=? WHERE ip_address=?"
                );
                update.setInt(1, visitCount);
                update.setString(2, ipAddress);
                update.executeUpdate();

            } else {
                visitCount = 1;

                PreparedStatement insert = con.prepareStatement(
                    "INSERT INTO page_visits(ip_address, visit_count) VALUES(?,?)"
                );
                insert.setString(1, ipAddress);
                insert.setInt(2, visitCount);
                insert.executeUpdate();
            }

            con.close();
        }
        catch(Exception e) {
            e.printStackTrace();
        }
        return visitCount;
    }

    // Add business logic below. (Right-click in editor and choose
    // "Insert Code > Add Business Method")
}
