<%@ page import="java.util.Random" %>
<%@page contentType="text/html" pageEncoding="UTF-8"%>

<%
    Random r = new Random();
    int captcha = 1000 + r.nextInt(9000);
    session.setAttribute("captcha", String.valueOf(captcha));
%>

<!DOCTYPE html>
<html>
<head>
<title>Fashion Store | Register</title>

<style>
body{
    margin:0;
    height:100vh;
    font-family:'Segoe UI', Arial;
    background:linear-gradient(135deg,#3e2723,#6d4c41);
    display:flex;
    align-items:center;
    justify-content:center;
}

.container{
    width:950px;
    background:#f5f1ee;
    padding:25px 35px;
    border-radius:16px;
    box-shadow:0 25px 40px rgba(0,0,0,0.4);
}

h2{
    text-align:center;
    color:#4e342e;
    margin-bottom:20px;
}

.row{
    display:flex;
    gap:30px;
}

.box{
    width:50%;
}

label{
    font-size:13px;
    font-weight:600;
    color:#4e342e;
}

input, textarea{
    width:100%;
    padding:8px;
    margin:5px 0 10px;
    border-radius:6px;
    border:1px solid #bcaaa4;
}

textarea{
    height:55px;
    resize:none;
}

.captcha-box{
    display:flex;
    align-items:center;
    gap:12px;
}

.captcha{
    background:#6d4c41;
    color:white;
    padding:10px 20px;
    font-size:22px;
    border-radius:6px;
    font-weight:bold;
}

button{
    display:block;
    margin:15px auto 0;
    width:220px;
    padding:10px;
    background:#6d4c41;
    color:white;
    border:none;
    border-radius:25px;
    font-size:15px;
    cursor:pointer;
}

button:hover{
    background:#4e342e;
}

.error{
    text-align:center;
    color:red;
    margin-top:8px;
}
</style>
</head>

<body>

<div class="container">
<h2>Create Account</h2>

<form action="register" method="post">
<div class="row">

<div class="box">
    <label>Username</label>
    <input type="text" name="username" required>

    <label>Login ID</label>
    <input type="text" name="login_id" required>

    <label>Email</label>
    <input type="email" name="email" required>

    <label>Phone</label>
    <input type="text" name="phone" required>

    <label>City</label>
    <input type="text" name="city">

    <label>State</label>
    <input type="text" name="state">

    <label>Country</label>
    <input type="text" name="country">

    <label>Pin Code</label>
    <input type="text" name="pin">
</div>

<div class="box">
    <label>Password</label>
    <input type="password" name="password" required>

    <label>Security Question</label>
    <input type="text" name="password_question">

    <label>Security Answer</label>
    <input type="text" name="password_answer">

    <label>Address</label>
    <textarea name="address"></textarea>

    <label>Captcha</label>
    <div class="captcha-box">
        <div class="captcha"><%= captcha %></div>
        <input type="text" name="captcha" required>
    </div>
</div>

</div>

<button type="submit">Register</button>
</form>

<% if(request.getParameter("captchaError")!=null){ %>
<div class="error">Invalid Captcha</div>
<% } %>

</div>

</body>
</html>
