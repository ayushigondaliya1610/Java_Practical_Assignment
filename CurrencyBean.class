package ejb;

import jakarta.annotation.Resource;
import jakarta.ejb.Stateless;
import javax.sql.DataSource;      
import java.sql.Connection;       
import java.sql.PreparedStatement;
import java.sql.ResultSet;


/**
 *
 * @author tejan
 */
@Stateless
public class CurrencyBean implements CurrencyBeanLocal {

    @Resource(lookup = "jdbc/currencydata_jndi")
    private DataSource ds;
    
    @Override
    public double convert(String from, String to, double amount) {
        double rate = 0;
        
        try{
            Connection con = ds.getConnection();
            PreparedStatement ps = con.prepareStatement("SELECT rate FROM currency_rates WHERE from_currency=? AND to_currency=?");
            
            ps.setString(1, from.trim());
            ps.setString(2, to.trim());
            
            ResultSet rs = ps.executeQuery();
        
            if (rs.next()) {
                rate = rs.getDouble("rate");
                System.out.println("Rate Found: " + rate);
            }
            else{
                System.out.println("No Rate Found!");
            }
        }
        catch(Exception e) {
            e.printStackTrace();
        }
        return amount * rate;
    }

   
}
