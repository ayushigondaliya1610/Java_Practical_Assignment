<%@page contentType="text/html" pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
    <title>Security Question</title>
    <style>
        body { background:#f2f2f2; font-family:Arial; }
        .box {
            width:450px; margin:100px auto;
            background:white; padding:30px;
            box-shadow:0 0 10px #aaa;
        }
        input, button {
            width:100%; padding:10px; margin-top:10px;
        }
        button {
            background:#2c3e50; color:white; border:none;
        }
    </style>
</head>
<body>

<div class="box">
    <h3>Answer Security Question</h3>

    <form action="forgotPassword" method="post">
        <input type="hidden" name="login_id" value="<%=session.getAttribute("login_id")%>">

        <p><b>Question:</b> <%=session.getAttribute("question")%></p>

        <input type="text" name="answer" placeholder="Enter your answer" required>
        <button type="submit">Verify</button>
    </form>

    <% if(request.getParameter("error")!=null){ %>
        <p style="color:red;">Wrong Answer!</p>
    <% } %>
</div>

</body>
</html>
