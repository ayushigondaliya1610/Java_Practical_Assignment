<%@ page import="java.util.Random" %>
<%@page contentType="text/html" pageEncoding="UTF-8"%>
<%
    Random r = new Random();
    int captcha = 1000 + r.nextInt(9000);
    session.setAttribute("captcha", String.valueOf(captcha));
%>
<!DOCTYPE html>
<html>
    <head>
        <title>Fashion Store | Auth</title>
        <style>
            :root {
                --primary: #8b6f55;
                --dark: #18232e;
                --light: #f6f5df;
                --text-muted: #666;
                --transition: all 0.4s ease;
            }

            body {
                margin: 0;
                height: 100vh;
                font-family: 'Segoe UI', Roboto, sans-serif;
                background: #e6d6c0;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .auth-container {
                width: 1100px;
                height: 750px; /* Increased height to fit all DB fields */
                background: white;
                display: flex;
                border-radius: 30px;
                overflow: hidden;
                box-shadow: 0 25px 50px rgba(0,0,0,0.15);
            }

            .image-side {
                width: 40%;
                background: url('https://images.unsplash.com/photo-1490481651871-ab68de25d43d?auto=format&fit=crop&q=80&w=1000') center/cover no-repeat;
                position: relative;
                display: flex;
                flex-direction: column;
                justify-content: flex-end;
                padding: 40px;
                color: white;
            }

            .image-side::before {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
            }

            .image-side-content {
                position: relative;
                z-index: 1;
            }

            .form-side {
                width: 60%;
                padding: 30px 50px;
                overflow-y: auto;
                position: relative;
            }

            .form-box {
                display: none;
                animation: fadeIn 0.5s ease;
            }
            .form-box.active {
                display: block;
            }

            @keyframes fadeIn {
                from {
                    opacity: 0;
                    transform: translateY(10px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            h2 {
                color: var(--dark);
                font-size: 26px;
                margin: 0 0 5px;
            }
            p.subtitle {
                color: var(--text-muted);
                font-size: 13px;
                margin-bottom: 20px;
            }

            label {
                display: block;
                font-size: 11px;
                font-weight: 700;
                margin-bottom: 4px;
                color: var(--dark);
                text-transform: uppercase;
            }

            input, select {
                width: 100%;
                padding: 10px;
                border: 1px solid #ddd;
                border-radius: 6px;
                box-sizing: border-box;
                margin-bottom: 12px;
            }

            input:focus {
                border-color: var(--primary);
                outline: none;
            }

            .row {
                display: flex;
                gap: 15px;
            }
            .col {
                flex: 1;
            }

            .btn {
                width: 100%;
                padding: 12px;
                background: var(--primary);
                color: white;
                border: none;
                border-radius: 25px;
                font-weight: 600;
                cursor: pointer;
                margin-top: 5px;
                transition: var(--transition);
            }

            .btn:hover {
                background: var(--dark);
            }

            .captcha-wrapper {
                display: flex;
                align-items: center;
                gap: 10px;
                margin-bottom: 12px;
            }

            .captcha-code {
                background: var(--dark);
                color: white;
                padding: 8px 12px;
                border-radius: 5px;
                font-weight: bold;
            }

            .toggle-link {
                text-align: center;
                margin-top: 15px;
                font-size: 14px;
            }
            .toggle-link a {
                color: var(--primary);
                text-decoration: none;
                font-weight: bold;
            }
        </style>
    </head>
    <body>

        <div class="auth-container">
            <div class="image-side">
                <div class="image-side-content">
                    <h1>Fashion Hub</h1>
                    <p>Your style journey starts here.</p>
                </div>
            </div>

            <div class="form-side">

                <div id="login-form" class="form-box active">
                    <h2>Welcome Back</h2>
                    <p class="subtitle">Enter your login ID and password.</p>
                    <form action="login" method="post">
                        <label>Login ID / Email</label>
                        <input type="text" name="login_id" required>

                        <label>Password</label>
                        <input type="password" name="password" required>

                        <button type="submit" class="btn">Login</button>
                    </form>
                    <div class="toggle-link">
                        New user? <a href="#" onclick="toggleAuth('register')">Register here</a>
                    </div>
                </div>

                <div id="register-form" class="form-box">
                    <h2>Create Account</h2>
                    <p class="subtitle">Fields with * are required.</p>

                    <form action="register" method="post">
                        <div class="row">
                            <div class="col">
                                <label>Username *</label>
                                <input type="text" name="username" required>
                            </div>
                            <div class="col">
                                <label>Login ID *</label>
                                <input type="text" name="login_id" required>
                            </div>
                        </div>
                        <div class="row">

                            <div class="col">
                                <label>Email</label>
                                <input type="text" name="pin">
                            </div>
                        </div>
                        <div class="row">

                            <div class="col">
                                <label>Password *</label>
                                <input type="password" name="password" required>
                            </div>
                            <div class="col">
                                <label>Phone *</label>
                                <input type="text" name="phone" required>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col">
                                <label>Security Question *</label>
                                <select name="password_question" required>
                                    <option value="" disabled selected>Select a question...</option>
                                    <option value="What was your best friend name?">What was your best friend name?</option>
                                    <option value="What was your first school?">What was your first school?</option>
                                    <option value="What is your favorite color?">What is your favorite color?</option>
                                    <option value="What city were you born in?">What city were you born in?</option>
                                </select>
                            </div>
                            <div class="col">
                                <label>Security Answer *</label>
                                <input type="text" name="password_answer" placeholder="Your answer" required>
                            </div>
                        </div>

                        <hr style="border:0; border-top:1px solid #eee; margin: 10px 0;">



                        <label>Address (Optional)</label>
                        <input type="text" name="address">

                        <div class="row">
                            <div class="col">
                                <label>City (Optional)</label>
                                <input type="text" name="city">
                            </div>
                            <div class="col">
                                <label>State (Optional)</label>
                                <input type="text" name="state">
                            </div>
                            <div class="col">
                                <label>Country (Optional)</label>
                                <input type="text" name="country">
                            </div>
                        </div>
                        <div class="row">

                            <div class="col">
                                <label>Pin Code (Optional)</label>
                                <input type="text" name="pin">
                            </div>
                            <div class="col">
                                <label>Verify Captcha *</label>
                                <div class="captcha-wrapper">
                                    <span class="captcha-code"><%= captcha%></span>
                                    <input type="text" name="captcha" placeholder="Enter code" required style="margin-bottom:0">
                                </div>
                            </div>

                        </div>

                        <button type="submit" class="btn">Register</button>
                    </form>
                    <div class="toggle-link">
                        Already have an account? <a href="#" onclick="toggleAuth('login')">Back to Login</a>
                    </div>
                </div>

            </div>
        </div>

        <script>
            function toggleAuth(type) {
                if (type === 'register') {
                    document.getElementById('login-form').classList.remove('active');
                    document.getElementById('register-form').classList.add('active');
                } else {
                    document.getElementById('register-form').classList.remove('active');
                    document.getElementById('login-form').classList.add('active');
                }
            }
        </script>

    </body>
</html>